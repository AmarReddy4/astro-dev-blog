---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {tags.map((tag) => (
    <a
      href={`/tags/${tag}`}
      class="inline-block px-2.5 py-0.5 text-xs font-medium rounded-full
             bg-sky-400/10 text-sky-400 hover:bg-sky-400/20 transition-colors"
    >
      {tag}
    </a>
  ))}
</div>
