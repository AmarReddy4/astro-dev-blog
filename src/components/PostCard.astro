---
import type { CollectionEntry } from "astro:content";
import TagList from "./TagList.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<article class="group">
  <a href={`/blog/${post.slug}`} class="block p-6 -mx-6 rounded-lg hover:bg-slate-800/50 transition-colors">
    <div class="flex flex-col gap-2">
      <time datetime={pubDate.toISOString()} class="text-sm text-slate-500">
        {formatDate(pubDate)}
      </time>
      <h3 class="text-xl font-semibold text-white group-hover:text-sky-400 transition-colors">
        {title}
      </h3>
      <p class="text-slate-400 leading-relaxed">{description}</p>
      {tags.length > 0 && (
        <div class="mt-2">
          <TagList tags={tags} />
        </div>
      )}
    </div>
  </a>
</article>
